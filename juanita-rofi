#!/bin/bash
set -euo pipefail

JUANITA="juanita"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/juanita"
mkdir -p "$CACHE_DIR"

PLAYER=""
for cmd in mpv vlc; do
    command -v "$cmd" &>/dev/null && PLAYER="$cmd" && break
done

show_poster() {
    local url="$1"
    [ -z "$url" ] && { rofi -e "No hay poster disponible"; return 1; }
    local ext="${url##*.}"; ext="${ext%%\?*}"
    [[ "$ext" =~ ^(jpg|jpeg|png|webp|gif)$ ]] || ext="jpg"
    local cache="$CACHE_DIR/$(echo -n "$url" | md5sum | cut -d' ' -f1).$ext"
    [ ! -f "$cache" ] && curl -sL -o "$cache" "$url" 2>/dev/null || true
    xdg-open "$cache" &>/dev/null &
    rofi -e "Poster abierto.\nCerrá la ventana cuando termines."
}

# Show a list of servers from json and let user pick one
# Returns the selected server as JSON on stdout
pick_server() {
    local json="$1" title="$2" action_label="$3"
    local count
    count=$(jq 'length' <<<"$json" 2>/dev/null || echo 0)
    [ "$count" -eq 0 ] && { rofi -e "No hay servidores disponibles"; return 1; }
    local lines=()
    for i in $(seq 0 $((count - 1))); do
        local lang name quality
        lang=$(jq -r ".[$i].lang // \"?\"" <<<"$json")
        name=$(jq -r ".[$i].name // \"?\"" <<<"$json")
        quality=$(jq -r ".[$i].quality // \"\"" <<<"$json")
        lines+=("[$lang] $name $quality")
    done
    local idx
    idx=$(printf '%s\n' "${lines[@]}" | rofi -dmenu -p "$action_label — $title" -i -format i)
    [ -z "$idx" ] && return 1
    jq -c ".[$idx]" <<<"$json"
}

# ── main ───────────────────────────────────────────────────────

query=$(rofi -dmenu -p "🔍 Juanita" -lines 1 \
    -theme-str 'entry { placeholder: "Buscar película o serie..."; }' < /dev/null)
[ -z "$query" ] && exit 1

movies=$(timeout 15 $JUANITA search "$query" --json 2>/dev/null || echo '[]')
series=$(timeout 15 $JUANITA series-search "$query" --json 2>/dev/null || echo '[]')

slugs=(); types=(); images=(); titles=(); years=(); ratings=()
display_lines=()

populate() {
    local json="$1" mtype="$2" icon="$3"
    local len entry slug title year rating image
    len=$(jq 'length' <<<"$json" 2>/dev/null || echo 0)
    for i in $(seq 0 $((len - 1))); do
        entry=$(jq -c ".[$i]" <<<"$json" 2>/dev/null)
        [ -z "$entry" ] && continue
        slug=$(jq -r '.slug // ""' <<<"$entry")
        title=$(jq -r '.title // ""' <<<"$entry")
        year=$(jq -r '.year // "?"' <<<"$entry")
        rating=$(jq -r '.rating // "?"' <<<"$entry")
        image=$(jq -r '.image // ""' <<<"$entry")
        [ -z "$slug" ] && continue
        slugs+=("$slug"); types+=("$mtype"); images+=("$image")
        titles+=("$title"); years+=("$year"); ratings+=("$rating")
        display_lines+=("$icon $title ($year) ★$rating")
    done
}

populate "$movies" "movie" "🎬"
populate "$series" "series" "📺"

if [ ${#slugs[@]} -eq 0 ]; then
    rofi -e "Sin resultados para:\n$query"
    exit 1
fi

selected_idx=$(printf '%s\n' "${display_lines[@]}" | \
    rofi -dmenu -p "📺 Resultados" -i -format i)
[ -z "$selected_idx" ] && exit 1

slug="${slugs[$selected_idx]}"
type="${types[$selected_idx]}"
title="${titles[$selected_idx]}"
year="${years[$selected_idx]}"
image="${images[$selected_idx]}"

# helper: play a stream URL
open_url() {
    local url="$1"
    xdg-open "$url" &>/dev/null &
    rofi -e "Abriendo en el navegador..."
}

play_hls() {
    local url="$1"
    if [ -n "$PLAYER" ]; then
        rofi -e "Iniciando stream...\n$title"
        "$PLAYER" "$url" &>/dev/null &
    else
        open_url "$url"
    fi
}

extract_hls() {
    local player_url="$1"
    local hls
    hls=$(curl -sL -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36" \
        -H "Referer: https://pelisjuanita.com/" \
        "$player_url" | python3 -c "
import sys, re
html = sys.stdin.read()
m = re.search(r'file:\s*\"([^\"]+)\"', html)
if m: print(m.group(1))
else:
    m = re.search(r\"file:\s*'([^']+)'\", html)
    if m: print(m.group(1))
" 2>/dev/null)
    echo "$hls"
}

# ── MOVIE ────────────────────────────────────────────────────────
if [ "$type" = "movie" ]; then
    actions=("▶ Ver/Stream" "⬇ Descargar" "🖼 Ver poster" "ℹ Info" "🌐 Abrir en navegador")
    action=$(printf '%s\n' "${actions[@]}" | \
        rofi -dmenu -p "🎬 $title ($year)" -i -format i)
    [ -z "$action" ] && exit 1

    info_json=$($JUANITA info "$slug" --json 2>/dev/null || echo '{}')
    servers=$(jq -c '.servers // []' <<<"$info_json" 2>/dev/null || echo '[]')

    case $action in
        0) # stream
            stream_servers=$(jq -c '[.[] | select(.type == "stream")]' <<<"$servers")
            selected=$(pick_server "$stream_servers" "$title" "▶ Stream") || exit 0
            stream_url=$(jq -r '.url // ""' <<<"$selected")
            if echo "$stream_url" | grep -q "player.php"; then
                hls=$(extract_hls "$stream_url")
                if [ -n "$hls" ]; then
                    play_hls "$hls"
                else
                    open_url "$stream_url"
                fi
            else
                open_url "$stream_url"
            fi ;;
        1) # download
            dl_servers=$(jq -c '[.[] | select(.type == "descarga")]' <<<"$servers")
            selected=$(pick_server "$dl_servers" "$title" "⬇ Descargar") || exit 0
            dl_url=$(jq -r '.download_url // .url // ""' <<<"$selected")
            [ -n "$dl_url" ] && open_url "$dl_url" || rofi -e "No hay enlace de descarga" ;;
        2) show_poster "$image" ;;
        3) echo "$info_json" | jq -r '"\(.title)\n\(.synopsis // "Sin sinopsis")\n\nSERVIDORES:"; .servers[] | "  [\(.lang)] \(.name) — \(.type) — \(.quality) — \(.url)"' | head -40 | \
            rofi -dmenu -p "ℹ $title" -width 90 -lines 20 ;;
        4) open_url "https://pelisjuanita.com/movies/movieInfo.php?title=$slug" ;;
    esac

# ── SERIES ───────────────────────────────────────────────────────
else
    # ── Season picker ──
    seasons_data=$($JUANITA series-seasons "$slug" --json 2>/dev/null)
    s_len=$(jq '.seasons | length' <<<"$seasons_data" 2>/dev/null || echo 0)
    [ "$s_len" -eq 0 ] && { rofi -e "No se encontraron temporadas"; exit 1; }
    s_lines=(); s_nums=()
    for i in $(seq 0 $((s_len - 1))); do
        num=$(jq -r ".seasons[$i]" <<<"$seasons_data")
        s_nums+=("$num"); s_lines+=("Temporada $num")
    done
    s_idx=$(printf '%s\n' "${s_lines[@]}" | rofi -dmenu -p "📺 $title" -i -format i)
    [ -z "$s_idx" ] && exit 1
    season="${s_nums[$s_idx]}"

    # ── Episode picker ──
    eps_json=$($JUANITA series-episodes "$slug" "$season" --json 2>/dev/null)
    e_len=$(jq 'length' <<<"$eps_json" 2>/dev/null || echo 0)
    [ "$e_len" -eq 0 ] && { rofi -e "No se encontraron episodios"; exit 1; }
    e_lines=()
    for i in $(seq 0 $((e_len - 1))); do
        e_title=$(jq -r ".[$i].title // empty" <<<"$eps_json")
        e_num=$(jq -r ".[$i].episode // $((i+1))" <<<"$eps_json")
        e_lines+=("E$e_num - ${e_title:-Sin título}")
    done
    e_idx=$(printf '%s\n' "${e_lines[@]}" | rofi -dmenu -p "📺 $title S${season}" -i -format i)
    [ -z "$e_idx" ] && exit 1
    e_num=$(jq -r ".[$e_idx].episode // \"\"" <<<"$eps_json")
    [ -z "$e_num" ] && e_num=$((e_idx + 1))

    # ── Actions (same as movies) ──
    actions=("▶ Ver/Stream" "⬇ Descargar" "🖼 Ver poster" "ℹ Info" "🌐 Abrir en navegador")
    action=$(printf '%s\n' "${actions[@]}" | \
        rofi -dmenu -p "📺 $title S${season}E${e_num}" -i -format i)
    [ -z "$action" ] && exit 1

    ep_info=$($JUANITA series-episode "$slug" "$season" "$e_num" --json 2>/dev/null || echo '{}')
    servers=$(jq -c '.servers // []' <<<"$ep_info" 2>/dev/null || echo '[]')

    case $action in
        0) # stream
            stream_servers=$(jq -c '[.[] | select(.type == "stream")]' <<<"$servers")
            selected=$(pick_server "$stream_servers" "$title S${season}E${e_num}" "▶ Stream") || exit 0
            stream_url=$(jq -r '.url // ""' <<<"$selected")
            if echo "$stream_url" | grep -q "player.php"; then
                hls=$(extract_hls "$stream_url")
                if [ -n "$hls" ]; then
                    play_hls "$hls"
                else
                    open_url "$stream_url"
                fi
            else
                open_url "$stream_url"
            fi ;;
        1) # download
            dl_servers=$(jq -c '[.[] | select(.type == "descarga")]' <<<"$servers")
            selected=$(pick_server "$dl_servers" "$title S${season}E${e_num}" "⬇ Descargar") || exit 0
            dl_url=$(jq -r '.download_url // .url // ""' <<<"$selected")
            [ -n "$dl_url" ] && open_url "$dl_url" || rofi -e "No hay enlace de descarga" ;;
        2) show_poster "$image" ;;
        3) echo "$ep_info" | jq -r '"\(.title)\n\(.synopsis // "Sin sinopsis")\n\nSERVIDORES:"; .servers[] | "  [\(.lang)] \(.name) — \(.type) — \(.quality) — \(.url)"' | head -40 | \
            rofi -dmenu -p "ℹ $title S${season}E${e_num}" -width 90 -lines 20 ;;
        4) open_url "https://pelisjuanita.com/series/serieInfo.php?nombreSerie=$slug" ;;
    esac
fi
